{
  "name": "@evotai/evot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "evot": "./bin/evot"
  },
  "napi": {
    "binaryName": "evot-napi",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build:napi": "napi build --manifest-path ../src/napi/Cargo.toml --output-dir . --release --platform --js src/native/binding.js --dts src/native/binding.d.ts",
    "build:cli": "bun build src/index.tsx --compile --define process.env.DEV='\"false\"' --define process.env.NODE_ENV='\"production\"' --outfile dist/evot",
    "dev": "bun run src/index.tsx",
    "test": "bun test tests/"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "figures": "^6.1.0",
    "ink": "^5.2.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.1",
    "@types/bun": "^1.2.0",
    "@types/diff": "^8.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.8.0"
  }
}
